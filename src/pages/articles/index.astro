---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/payload';

const res = await getArticles(20);
const articles = res?.docs ?? [];

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
---

<BaseLayout title="Articles" description="Jiu-jitsu articles, training tips, and culture pieces.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-8">Articles</h1>

    {articles.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            class="bg-white/5 border border-white/10 rounded-lg overflow-hidden hover:border-white/20 transition-colors group"
          >
            {article.featuredImage && (
              <img
                src={article.featuredImage.sizes?.card?.url ?? article.featuredImage.url}
                alt={article.featuredImage.alt || article.title}
                class="w-full aspect-video object-cover"
              />
            )}
            <div class="p-6">
              <h2 class="font-bold text-lg mb-2 group-hover:text-brand-red transition-colors">
                {article.title}
              </h2>
              {article.excerpt && (
                <p class="text-brand-subtle text-sm line-clamp-3 mb-3">{article.excerpt}</p>
              )}
              <div class="flex items-center gap-3 text-brand-faint text-xs">
                {article.author && <span>{article.author}</span>}
                <time datetime={article.createdAt}>{formatDate(article.createdAt)}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
        <p class="text-brand-subtle">Articles coming soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
