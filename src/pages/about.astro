---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Our story, vision, sponsors, and ambassadors.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-8">About</h1>

    <div class="space-y-12">
      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">Our Story</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8">
          <p class="text-brand-muted leading-relaxed">
            Jiu Jitsu Style is being strategically relaunched as a premier digital media, lifestyle,
            and community platform within the global jiu-jitsu ecosystem. Our objective is to build
            the most inspirational, entertaining, and culturally relevant digital hub in the sport.
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">Our Vision</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8">
          <p class="text-brand-muted leading-relaxed">
            To build Jiu Jitsu Style into the most dynamic, authentic, and culturally connected
            brand in the global jiu-jitsu community.
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">Sponsors</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
          <p class="text-brand-subtle">Sponsor listings coming soon.</p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">Ambassadors</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
          <p class="text-brand-subtle">Ambassador profiles coming soon.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
