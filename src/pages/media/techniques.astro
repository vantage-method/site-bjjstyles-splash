---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechniqueFilter from '../../components/media/TechniqueFilter';
import { getTechniques } from '../../lib/payload';

const res = await getTechniques(100);
const techniques = (res?.docs ?? []).map((t) => ({
  id: t.id,
  title: t.title,
  slug: t.slug,
  position: t.position,
  gi: t.gi,
  videoUrl: t.videoUrl,
  thumbnail: t.thumbnail
    ? {
        url: t.thumbnail.url,
        alt: t.thumbnail.alt,
        sizes: t.thumbnail.sizes?.card ? { card: { url: t.thumbnail.sizes.card.url } } : undefined,
      }
    : undefined,
}));
---

<BaseLayout title="Technique Library" description="Browse jiu-jitsu techniques by position and style.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-8">Technique Library</h1>

    {techniques.length > 0 ? (
      <TechniqueFilter client:load techniques={techniques} />
    ) : (
      <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
        <p class="text-brand-subtle">
          Technique library with position and Gi/No-Gi filters coming soon.
        </p>
      </div>
    )}
  </section>
</BaseLayout>
