---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mission" description="Our mission to fight human trafficking through jiu-jitsu.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-8">Our Mission</h1>

    <div class="space-y-12">
      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">The Mission</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8">
          <p class="text-brand-muted leading-relaxed">
            Jiu Jitsu Style exists at the intersection of sport, culture, and purpose. We believe
            the jiu-jitsu community has the power to drive real change in the world.
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">Partnership with Skull Games</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8">
          <p class="text-brand-muted leading-relaxed">
            Through our partnership with Skull Games, we're leveraging the jiu-jitsu community's
            strength and spirit to combat human trafficking worldwide.
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-4">10% Profit Commitment</h2>
        <div class="bg-white/5 border border-white/10 rounded-lg p-8">
          <p class="text-brand-muted leading-relaxed">
            10% of all Jiu Jitsu Style profits go directly toward fighting human trafficking.
            Every purchase you make contributes to something bigger than sport.
          </p>
        </div>
      </div>

      <div class="text-center">
        <a
          href="#donate"
          class="inline-block bg-brand-red text-brand-white font-semibold px-8 py-3 text-sm uppercase tracking-wider hover:brightness-110 transition-all duration-200"
        >
          Donate Now
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
