---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Jiu Jitsu Style.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-4">Contact</h1>
    <p class="text-brand-muted mb-8">
      Have a question, partnership inquiry, or just want to connect? Reach out below.
    </p>

    <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
      <p class="text-brand-subtle">Contact form coming soon.</p>
    </div>
  </section>
</BaseLayout>
