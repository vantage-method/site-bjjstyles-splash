---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Store" description="Jiu-jitsu gear, apparel, supplements, and more.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-8">Store</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
        <h2 class="text-xl font-bold uppercase tracking-wide mb-2">Jiu-Jitsu Gear</h2>
        <p class="text-brand-subtle text-sm">Coming soon.</p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
        <h2 class="text-xl font-bold uppercase tracking-wide mb-2">AI Jiu-Jitsu Journal</h2>
        <p class="text-brand-subtle text-sm">Coming soon.</p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
        <h2 class="text-xl font-bold uppercase tracking-wide mb-2">Supplements</h2>
        <p class="text-brand-subtle text-sm">Coming soon.</p>
      </div>
    </div>
  </section>
</BaseLayout>
