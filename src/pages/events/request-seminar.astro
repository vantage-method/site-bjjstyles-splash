---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Request a Seminar" description="Request a jiu-jitsu seminar from our ambassadors and athletes.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold uppercase tracking-wide mb-4">Request a Seminar</h1>
    <p class="text-brand-muted mb-8">
      Interested in hosting a seminar at your academy? Fill out the form below and we'll
      connect you with our team.
    </p>

    <div class="bg-white/5 border border-white/10 rounded-lg p-8 text-center">
      <p class="text-brand-subtle">Seminar request form coming soon.</p>
    </div>
  </section>
</BaseLayout>
