---
import { SOCIAL } from '../../lib/constants';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['flex items-center gap-5', className]}>
  <a
    href={SOCIAL.instagram.url}
    target="_blank"
    rel="noopener"
    aria-label={SOCIAL.instagram.label}
    class="text-brand-subtle hover:text-brand-white transition-colors duration-200"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5"/>
      <circle cx="12" cy="12" r="5"/>
      <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
    </svg>
  </a>
  <a
    href={SOCIAL.facebook.url}
    target="_blank"
    rel="noopener"
    aria-label={SOCIAL.facebook.label}
    class="text-brand-subtle hover:text-brand-white transition-colors duration-200"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
    </svg>
  </a>
  <a
    href={SOCIAL.x.url}
    target="_blank"
    rel="noopener"
    aria-label={SOCIAL.x.label}
    class="text-brand-subtle hover:text-brand-white transition-colors duration-200"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
</div>
